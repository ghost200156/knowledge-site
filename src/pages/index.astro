---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublicPosts } from "../lib/content";
import { withBase } from "../lib/paths";

const posts = await getPublicPosts();
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) =>
  a.localeCompare(b, "zh-CN")
);
const latestPost = posts[0];
---

<BaseLayout>
  <section class="cover" aria-labelledby="site-title">
    <div class="cover-intro">
      <p class="eyebrow">Public knowledge index</p>
      <h1 id="site-title">未完成知识的公开索引</h1>
      <p class="intro-text">从 Obsidian 里筛出可以公开的想法，先形成可读的路径，再慢慢长成语义地图。</p>

      <dl class="site-stats" aria-label="站点状态">
        <div>
          <dt>{posts.length}</dt>
          <dd>公开笔记</dd>
        </div>
        <div>
          <dt>{tags.length}</dt>
          <dd>主题</dd>
        </div>
        <div>
          <dt>MD</dt>
          <dd>内容源</dd>
        </div>
      </dl>
    </div>

    {
      latestPost && (
        <article class="featured-note">
          <p class="panel-label">Latest</p>
          <a href={withBase(`/posts/${latestPost.id}/`)}>
            <span class="note-type">{latestPost.data.type}</span>
            <h2>{latestPost.data.title}</h2>
            <p>{latestPost.data.description}</p>
            <time datetime={latestPost.data.pubDate.toISOString()}>
              {latestPost.data.pubDate.toLocaleDateString("zh-CN")}
            </time>
          </a>
        </article>
      )
    }

    <aside class="map-module" aria-label="知识地图">
      <div class="map-copy">
        <p class="panel-label">Map</p>
        <p>notes / links / routes</p>
      </div>
      <img src={withBase("/knowledge-map.png")} alt="" loading="eager" />
    </aside>
  </section>

  <section class="note-index" id="notes" aria-labelledby="notes-title">
    <div class="section-heading">
      <div>
        <p class="section-kicker">Published notes</p>
        <h2 id="notes-title">公开笔记</h2>
      </div>
      <p>{posts.length} 篇</p>
    </div>

    {
      posts.length > 0 ? (
        <ol class="note-list">
          {posts.map((post, index) => (
            <li>
              <a href={withBase(`/posts/${post.id}/`)}>
                <span class="note-number">{String(index + 1).padStart(2, "0")}</span>
                <span class="note-main">
                  <span class="note-row">
                    <strong>{post.data.title}</strong>
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString("zh-CN")}
                    </time>
                  </span>
                  <span>{post.data.description}</span>
                </span>
                <span class="note-tags">{post.data.tags.join(" / ")}</span>
              </a>
            </li>
          ))}
        </ol>
      ) : (
        <p class="empty-state">还没有公开内容。</p>
      )
    }
  </section>

  {
    tags.length > 0 && (
      <section class="topic-index" id="topics" aria-labelledby="tags-title">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Topics</p>
            <h2 id="tags-title">主题</h2>
          </div>
        </div>
        <div class="tags">
          {tags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
