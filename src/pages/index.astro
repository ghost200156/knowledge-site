---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublicPosts } from "../lib/content";
import { withBase } from "../lib/paths";

const posts = await getPublicPosts();
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) =>
  a.localeCompare(b, "zh-CN")
);
---

<BaseLayout>
  <section class="overview" aria-labelledby="site-title">
    <div class="intro">
      <p class="eyebrow">Knowledge Lab</p>
      <h1 id="site-title">知识实验室</h1>
      <p class="intro-text">
        这里会逐步沉淀公开笔记、长文、项目记录和知识地图。
      </p>
    </div>

    <div class="map-panel" aria-label="知识节点预览">
      <img src={withBase("/knowledge-map.png")} alt="" loading="eager" />
    </div>
  </section>

  <section class="content-band" aria-labelledby="latest-title">
    <div class="section-heading">
      <h2 id="latest-title">最新公开内容</h2>
      <p>{posts.length} 篇</p>
    </div>

    {
      posts.length > 0 ? (
        <div class="post-list">
          {posts.map((post) => (
            <article class="post-card">
              <a href={withBase(`/posts/${post.id}/`)} class="post-link">
                <span class="post-type">{post.data.type}</span>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
                <div class="post-meta">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString("zh-CN")}
                  </time>
                  <span>{post.data.tags.join(" / ")}</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <p class="empty-state">还没有公开内容。</p>
      )
    }
  </section>

  {
    tags.length > 0 && (
      <section class="tag-band" aria-labelledby="tags-title">
        <h2 id="tags-title">主题</h2>
        <div class="tags">
          {tags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
