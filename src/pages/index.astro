---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublicPosts } from "../lib/content";
import { withBase } from "../lib/paths";

const posts = await getPublicPosts();
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) =>
  a.localeCompare(b, "zh-CN")
);
const latestPost = posts[0];
const otherPosts = posts.slice(1);

const labModules = [
  {
    title: "Obsidian 写作流",
    description: "先用 Markdown 管住内容边界，再逐步接入自动同步、元数据检查和公开发布。",
    meta: "content pipeline",
  },
  {
    title: "AI 助手层",
    description: "以后可以生成摘要、关联旧笔记、提出反问，把站点从文章列表变成知识接口。",
    meta: "agent ready",
  },
  {
    title: "数字花园",
    description: "文章、短笔记、项目和想法流并列生长，不必被传统博客的时间线限制住。",
    meta: "garden mode",
  },
];
---

<BaseLayout>
  <section class="hero" aria-labelledby="site-title">
    <div class="hero-copy">
      <p class="eyebrow">Menglai Knowledge Lab</p>
      <h1 id="site-title">把笔记、想法和 AI 实验放在同一个空间里。</h1>
      <p class="intro-text">
        这里会先从 Obsidian 公开笔记开始，慢慢长成文章、项目、想法流和 AI 助手共同工作的个人知识空间。
      </p>

      <div class="hero-actions" aria-label="快速入口">
        <a class="primary-link" href="#writing">阅读最新内容</a>
        <a class="text-link" href="#lab">查看实验模块</a>
      </div>

      <dl class="site-stats" aria-label="站点状态">
        <div>
          <dt>{posts.length}</dt>
          <dd>公开内容</dd>
        </div>
        <div>
          <dt>{tags.length}</dt>
          <dd>主题标签</dd>
        </div>
        <div>
          <dt>MD</dt>
          <dd>写作源</dd>
        </div>
      </dl>
    </div>

    <figure class="hero-visual">
      <img src={withBase("/knowledge-room.png")} alt="由笔记、星图和界面窗口组成的知识实验室插画" loading="eager" />
      <figcaption>
        <span>notes</span>
        <span>agents</span>
        <span>garden</span>
      </figcaption>
    </figure>
  </section>

  <section class="signal-strip" aria-label="站点方向">
    <p>不是传统博客。</p>
    <p>它会从公开笔记开始，连接项目、灵感、阅读和自动化工作流。</p>
  </section>

  <section class="writing-section" id="writing" aria-labelledby="writing-title">
    <div class="section-heading">
      <p class="section-kicker">Recent Writing</p>
      <h2 id="writing-title">最近公开</h2>
    </div>

    {
      latestPost ? (
        <div class="writing-grid">
          <article class="featured-writing">
            <a href={withBase(`/posts/${latestPost.id}/`)}>
              <span class="note-type">{latestPost.data.type}</span>
              <h3>{latestPost.data.title}</h3>
              <p>{latestPost.data.description}</p>
              <time datetime={latestPost.data.pubDate.toISOString()}>
                {latestPost.data.pubDate.toLocaleDateString("zh-CN")}
              </time>
            </a>
          </article>

          <ol class="writing-list">
            {[latestPost, ...otherPosts].map((post, index) => (
              <li>
                <a href={withBase(`/posts/${post.id}/`)}>
                  <span class="note-number">{String(index + 1).padStart(2, "0")}</span>
                  <span class="note-main">
                    <strong>{post.data.title}</strong>
                    <span>{post.data.description}</span>
                  </span>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString("zh-CN")}
                  </time>
                </a>
              </li>
            ))}
          </ol>
        </div>
      ) : (
        <p class="empty-state">还没有公开内容。</p>
      )
    }
  </section>

  <section class="lab-section" id="lab" aria-labelledby="lab-title">
    <div class="section-heading">
      <p class="section-kicker">Lab Modules</p>
      <h2 id="lab-title">之后可以长出来的部分</h2>
    </div>
    <div class="lab-grid">
      {
        labModules.map((module) => (
          <article class="lab-card">
            <p>{module.meta}</p>
            <h3>{module.title}</h3>
            <span>{module.description}</span>
          </article>
        ))
      }
    </div>
  </section>

  {
    tags.length > 0 && (
      <section class="topic-section" id="topics" aria-labelledby="tags-title">
        <div class="section-heading">
          <p class="section-kicker">Topics</p>
          <h2 id="tags-title">主题索引</h2>
        </div>
        <div class="tags">
          {tags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
