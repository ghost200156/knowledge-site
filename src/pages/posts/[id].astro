---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublicPosts } from "../../lib/content";
import { withBase } from "../../lib/paths";

export async function getStaticPaths() {
  const posts = await getPublicPosts();

  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | 知识实验室`} description={post.data.description}>
  <article class="article">
    <a class="back-link" href={withBase("/")}>返回首页</a>

    <header class="article-header">
      <div class="article-meta">
        <span>{post.data.type}</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString("zh-CN")}
        </time>
      </div>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <p class="article-tags">{post.data.tags.join(" / ")}</p>
    </header>

    <div class="article-layout">
      <aside class="article-side" aria-label="文章信息">
        <p>Source</p>
        <strong>Obsidian Markdown</strong>
        <span>公开内容需要同时满足 published 和 public。</span>
      </aside>
      <div class="article-body">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
