---
import "../styles/global.css";
import { withBase } from "../lib/paths";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "知识实验室",
  description = "一个从 Obsidian 笔记生长出来的个人知识站。",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={withBase("/")} aria-label="回到首页">
          <span class="brand-mark" aria-hidden="true">知</span>
          <span class="brand-text">
            <strong>知识实验室</strong>
            <small>Obsidian Garden</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="站点导航">
          <a href={withBase("/#writing")}>文章</a>
          <a href={withBase("/#lab")}>实验</a>
          <a href={withBase("/#topics")}>主题</a>
        </nav>
      </header>

      <main class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <span>Written in Obsidian</span>
        <span>Built with Astro and GitHub Pages</span>
      </footer>
    </div>
  </body>
</html>
